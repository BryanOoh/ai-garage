# Public site URL (used for OG/canonical links)
NEXT_PUBLIC_SITE_URL=https://ai-garage.dev

# GitHub repositories
NEXT_PUBLIC_GITHUB_AI_GARAGE_URL=https://github.com/bryanoh/ai-garage
NEXT_PUBLIC_GITHUB_PIXELAGENT_URL=https://github.com/bryanoh/pixelagent

# PixelAgent docs — leave empty until published
# NEXT_PUBLIC_PIXELAGENT_DOCS_URL=https://pixelagent.dev/docs

# Unlock Install+ sections locally or in production (overview + What it does stay public)
# NEXT_PUBLIC_PIXELAGENT_PAGE_ENABLED=true

# Private preview (server-only) — visit /?pixelagent_preview=<secret> once to unlock Install+ in your browser
# PIXELAGENT_PREVIEW_SECRET=your-long-random-string
